#!/usr/bin/env bash
# follow_pi - Pretty-print a live pi session, auto-switching to new sessions
# Usage: follow_pi [session.jsonl | sessions-dir]
#   Without arguments, derives the session directory from $PWD (same as pi does)
#   and auto-switches to the newest session. So just run it from the same
#   directory where you started pi.
#   With a .jsonl file, tails just that file (no auto-switch).
#   With a directory, watches that directory for the latest/new sessions.

JQ_FILTER='
  select(.type == "message") |
  if .message.role == "user" then
    "\n\u001b[1;34m━━━ USER ━━━\u001b[0m\n" + (
      if (.message.content | type) == "string" then .message.content
      else [.message.content[] | select(.type == "text") | .text] | join("\n")
      end)
  elif .message.role == "assistant" then
    "\n\u001b[1;32m━━━ ASSISTANT ━━━\u001b[0m\n" + (
      if (.message.content | type) == "string" then .message.content
      else [.message.content[] |
        if .type == "text" then .text
        elif .type == "toolCall" then "\u001b[33m⚡ " + .name + "(\u001b[0m" + (.arguments | tostring | .[0:200]) + "\u001b[33m)\u001b[0m"
        elif .type == "thinking" then "\u001b[3;38;5;246m💭 " + (.thinking | .[0:400]) + (if (.thinking | length) > 400 then "…" else "" end) + "\u001b[0m"
        else empty end
      ] | join("\n")
      end)
  elif .message.role == "toolResult" then
    "\u001b[36m← " + .message.toolName + (if .message.isError then " ✗" else " ✓" end) + "\u001b[0m " + (
      [.message.content[] | select(.type == "text") | .text | .[0:300]] | join("\n"))
  elif .message.role == "bashExecution" then
    "\u001b[35m$ " + .message.command + "\u001b[0m\n" + (.message.output | .[0:500])
  elif .message.role == "compactionSummary" then
    "\u001b[2m📦 Compacted: " + (.message.summary | .[0:200]) + "\u001b[0m"
  else empty end
'

# Derive session directory from a working directory, same logic as pi:
#   --${cwd stripped of leading /; all /\: replaced with -}--
cwd_to_session_dir() {
  local cwd="$1"
  local safe
  safe="$(echo "$cwd" | sed 's|^/||; s|[/\\:]|-|g')"
  echo "$HOME/.pi/agent/sessions/--${safe}--"
}

find_newest() {
  local dir="$1"
  fd -e jsonl -a . "$dir" -x stat -f '%m %N' {} 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-
}

# --- Single-file mode (no auto-switch) ---
if [ -n "$1" ] && [ -f "$1" ]; then
  echo -e "\e[1;33m▶ Following: $1\e[0m" >&2
  tail -f "$1" | jq -r "$JQ_FILTER"
  exit 0
fi

# --- Determine sessions directory ---
if [ -n "$1" ] && [ -d "$1" ]; then
  # Explicit directory argument
  SESSIONS_DIR="$1"
else
  # No argument: derive from PWD (same as pi does)
  SESSIONS_DIR="$(cwd_to_session_dir "$PWD")"
fi

if [ ! -d "$SESSIONS_DIR" ]; then
  echo "Session directory not found: $SESSIONS_DIR" >&2
  echo "Make sure you run follow_pi from the same directory where you started pi." >&2
  exit 1
fi

echo -e "\e[1;33m▶ Watching: $SESSIONS_DIR\e[0m" >&2

# --- Auto-switch mode ---
cleanup() {
  [ -n "$TAIL_PID" ] && kill "$TAIL_PID" 2>/dev/null
  exit 0
}
trap cleanup INT TERM

CURRENT_FILE=""
TAIL_PID=""

while true; do
  NEWEST="$(find_newest "$SESSIONS_DIR")"

  if [ -z "$NEWEST" ]; then
    echo "Waiting for session files in $SESSIONS_DIR ..." >&2
    sleep 2
    continue
  fi

  if [ "$NEWEST" != "$CURRENT_FILE" ]; then
    # Kill previous tail if running
    if [ -n "$TAIL_PID" ]; then
      kill "$TAIL_PID" 2>/dev/null
      wait "$TAIL_PID" 2>/dev/null
    fi

    CURRENT_FILE="$NEWEST"
    echo -e "\n\e[1;33m▶ Following: $CURRENT_FILE\e[0m" >&2
    tail -f "$CURRENT_FILE" | jq -r "$JQ_FILTER" &
    TAIL_PID=$!
  fi

  sleep 2
done
